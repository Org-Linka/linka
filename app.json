{
  "expo": {
    "name": "Linka",
    "slug": "linka",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/public/icon.png",
    "scheme": "Linka",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tenmenezes.linka",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "development",
        "com.apple.security.application-groups": [
          "group.com.tenmenezes.linka.onesignal"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/public/android-icon-foreground.png",
        "backgroundImage": "./assets/public/android-icon-background.png",
        "monochromeImage": "./assets/public/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tenmenezes.linka"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/public/favicon.png"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development",
          "smallIcons": [
            "./assets/public/notifications/ic_stat_onesignal_default.png"
          ],
          "largeIcons": [
            "./assets/public/notifications/ic_onesignal_large_icon_default.png"
          ],
          "smallIconAccentColor": "#38BDF8"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/public/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7c847475-5643-4947-a336-f1b69fd281f3"
      }
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/7c847475-5643-4947-a336-f1b69fd281f3"
    },
    "owner": "tenmenezes"
  }
}
