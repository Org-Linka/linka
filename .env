# Linka - Environment Variables Example
#
# Copy this file to `.env` and fill the values for your local environment.
# Do not commit `.env`, private keys, service role keys, passwords, or admin credentials.
#
# Expo exposes variables prefixed with EXPO_PUBLIC_ to the client app.
# Keep only public/safe values with this prefix.

# App
EXPO_PUBLIC_APP_NAME=Linka
EXPO_PUBLIC_APP_ENV=development

# Supabase - db_linka
# Expected URL format: https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://foxxfguvyectiunpptoy.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_FK43oCY2YMSD4aOntMqeJg_H9Q_CPji
# Supabase Storage - planned public bucket names
# Uncomment only when these buckets are created and used by the app.
# EXPO_PUBLIC_SUPABASE_AVATARS_BUCKET=avatars
# EXPO_PUBLIC_SUPABASE_PROJECT_COVERS_BUCKET=project-covers
# EXPO_PUBLIC_SUPABASE_COURSE_FILES_BUCKET=course-files

# Notifications - planned integration
# EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# Analytics - planned integration
# EXPO_PUBLIC_FIREBASE_ANALYTICS_ENABLED=false

# Payments - planned integration
# Use only publishable/client-safe keys here. Never add Stripe secret keys.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
